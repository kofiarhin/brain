{
  "name": "brain",
  "version": "2.0.0",
  "description": "Personal Operating System: MongoDB memory, Codex CLI brain, React interface.",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install",
    "test": "npm run test:server && npm run test:client",
    "test:server": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:client": "npm --prefix client run test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
