{
  "name": "brain",
  "version": "2.0.0",
  "description": "Personal Operating System: MongoDB memory, Codex CLI brain, React interface.",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "build": "npm run heroku-postbuild",
    "heroku-postbuild": "npm --prefix client ci && npm --prefix client run build",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install",
    "test": "npm run test:server && npm run test:client",
    "test:server": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:client": "npm --prefix client run test",
    "brain:good-morning": "node server/scripts/goodMorning.js",
    "brain:replan-day": "node server/scripts/replanDay.js",
    "brain:refresh-brain": "node server/scripts/refreshBrain.js",
    "brain:update-brain": "node server/scripts/updateBrain.js",
    "brain:export": "node scripts/exportKnowledgeBase.js",
    "brain:clear": "node scripts/clearKnowledgeBase.js",
    "brain:import": "node scripts/importKnowledgeBase.js",
    "seed:context": "node scripts/seedContext.js",
    "brain:generate-post": "node server/scripts/generatePost.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
